# App
APP_NAME=Sâm Bà Đen API
ENV=development
DEBUG=true

# Database (asyncpg)
DATABASE_URL=postgresql+asyncpg://samba:samba@postgres:5432/sambaden
DB_ECHO=false

# Redis
REDIS_URL=redis://redis:6379/0

# JWT — ĐỔI jwt_secret trong production (chuỗi ngẫu nhiên dài)
JWT_SECRET=CHANGE_ME_use_a_long_random_secret_string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL=604800

# CORS (JSON array)
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Order
ORDER_NO_PREFIX=SBD

# VNPay
VNPAY_TMN_CODE=SBD2026
VNPAY_HASH_SECRET=SANDBOX_HASH_SECRET_XYZ
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:5173/portal/payment/callback
